<div class="containar">
  <div class="row">
    <div class="col-sm-12 colpmd-8 col-lg-5 px-5 px-sm-0 mx-auto">
      <h1>Editing Book</h1>
      <%= form_with model: @book do |f| %>
        <div class="form-group">
          <%= f.label :title, "Title" %><br>
          <%= f.text_field :title %><br>
        </div>
        <div class="form-group">
          <%= f.label :opinion, "Opinion" %><br>
          <%= f.text_area :opinion %><br>
        </div>
          <div class="form-group">
          <%= f.submit "Update date", class: "btn btn-success" %>
        </div> 
        <%= link_to 'show', book_path %>
        |
        <%= link_to 'back', books_path %>
      <% end %>
    </div>
  </div>
</div>
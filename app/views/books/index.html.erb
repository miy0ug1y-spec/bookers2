<%= render 'list', user: Current.user, book: @book %>


<div class="col-md-8 offset-md-1">
<h2>Books</h2>
 <table class="table table-hover">
        <thead>
          <tr class="border-top">
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody class="table">
         <% @books.each do |book| %>
            <tr class="border-top" style="border-style: hidden;">
              <td>
                <%= link_to user_path(book.user) do %>
                  <% if book.user.profile_image.attached? %>
                    <%= image_tag book.user.profile_image, size: "80x80" %>
                  <% else %>
                    <%= image_tag "default-image.jpg", size: "80x80" %>
                  <% end %>
                  <% end %>
              </td>
              <td><%= link_to book.title, book_path(book.id) %></td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>



<main>
<div class="container px-5 px-sm-0">
  <div class="row">
   <div class="col-md-3">
    <h2>User info</h2>
    <% if @user.image.attached? %>
      <%= image_tag @user.image, size: "100x100" %>
    <% else %>
      <%= image_tag 'default-image.jpg', size: "100x100" %>
    <% end %>
    <table class="table">
      <tbody>
        <tr class="border-top"></tr>
        <tr>
          <th>name</th>
          <th><%= @user.name %></th>
        </tr>
        <tr class="border-top" style="border-style: hidden;">
          <th>introduction</th>
          <th><%= @user.introduction %></th>
        </tr>
      </tbody>
    </table>

<div class="row">
  <%= link_to edit_user_path(@user), class: "btn btn-sm btn-outline-secondary text-secondary border-secondary" do %>
    <i class="fa-solid fa-user-gear"></i>
  <% end %>
</div>


<h2 class="mt-3">New book</h2>
<%= form_with model: @book do |f| %>
  <div class="form-group">
   <label for="book_title">Title</label><br>
    <%= f.text_field :title, class: "form-control" %><br>
  </div>
  <div class="form-group">
    <label for="book_opinion">Opinion</label><br>
    <%= f.text_area :body, class: "form-control" %><br>
  </div>
  <div class="form-group">
    <%= f.submit 'Create Book', class: "btn btn-success" %><br>
  </div>
<% end %>
</div>

<div class="col-md-8 offset-md-1">
<h2>Books</h2>
 <table class="table table-hover">
        <thead>
          <tr class="border-top">
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
            <th colspan="3"></th>
          </tr>
        </thead>
        <tbody class="table-group-divider">
         <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <% if book.user.image.attached? %>
                    <%= image_tag book.user.image, size: "80x80" %>
                  <% else %>
                    <%= image_tag "default-image.jpg", size: "80x80" %>
                  <% end %>
                  <% end %>
              </td>
              <td><%= link_to book.title, book_path(book) %></td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</main>

